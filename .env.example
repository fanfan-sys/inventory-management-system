# Supabase 数据库连接
# 获取方式: Supabase Dashboard → Settings → Database → Connection string

# Connection Pooling (推荐用于 Vercel 等生产环境，支持 IPv4)
DATABASE_URL=your_supabase_pooler_url_with_password

# Direct Connection (用于 prisma db push / prisma db seed 等数据库迁移操作)
DIRECT_URL=your_supabase_direct_url_with_password
