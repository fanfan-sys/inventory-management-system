# Supabase 数据库连接
# 获取方式: Supabase Dashboard → Settings → Database → Connection string

# Connection Pooling (推荐用于 Vercel 等生产环境)
# URI 格式: postgresql://postgres.[项目引用]:[密码]@aws-0-[区域].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=your_supabase_pooler_url

# Direct Connection (用于 prisma migrate / prisma db push 等数据库迁移操作)
# URI 格式: postgresql://postgres:[密码]@db.[项目引用].supabase.co:5432/postgres
DIRECT_URL=your_supabase_direct_url
